# Copy this file to .env and fill in real values for production.

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — by default Marketly uses SQLite (zero setup).
# To switch to PostgreSQL: either set DATABASE_URL below, OR uncomment and fill in the
# POSTGRES_* block. As long as BOTH are empty/unset, Django falls back to SQLite.
DATABASE_URL=
# POSTGRES_DB=marketly
# POSTGRES_USER=marketly
# POSTGRES_PASSWORD=marketly
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Email
# Default: console backend — prints emails (with verification codes) to the runserver terminal.
# For real delivery via Gmail, see GMAIL_SETUP.md for the 3-step walkthrough.
#
# To send real emails via Gmail, flip EMAIL_BACKEND to the SMTP backend and fill the
# EMAIL_HOST_USER / EMAIL_HOST_PASSWORD fields below. EMAIL_HOST_PASSWORD must be a
# 16-character Google App Password (https://myaccount.google.com/apppasswords), NOT
# your normal Gmail password. Requires 2-Step Verification enabled on the account.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend   # uncomment for real email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=                                                # your.address@gmail.com
EMAIL_HOST_PASSWORD=                                            # 16-char App Password (no spaces)
DEFAULT_FROM_EMAIL=Marketly <no-reply@marketly.local>           # when using Gmail, set this to your Gmail address

# Stripe (test keys — get them at https://dashboard.stripe.com/test/apikeys)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social auth (fill via Django admin -> Social applications, OR via env)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Site URL (used for building absolute URLs in emails and Stripe redirects)
SITE_URL=http://localhost:8000
