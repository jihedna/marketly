# Copy this file to .env and fill in real values for production.

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite for local dev)
DATABASE_URL=
# Or individual fields (used only if DATABASE_URL is empty)
POSTGRES_DB=marketly
POSTGRES_USER=marketly
POSTGRES_PASSWORD=marketly
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Email (console backend by default — prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Marketly <no-reply@marketly.local>

# Stripe (test keys — get them at https://dashboard.stripe.com/test/apikeys)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social auth (fill via Django admin -> Social applications, OR via env)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Site URL (used for building absolute URLs in emails and Stripe redirects)
SITE_URL=http://localhost:8000
